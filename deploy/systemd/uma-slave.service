[Unit]
Description=poly_uma HTTP and WebSocket slave relay
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=uma-slave
Group=uma-slave
WorkingDirectory=/opt/uma-slave
EnvironmentFile=-/opt/uma-slave/.uma-slave.env
ExecStart=/opt/uma-slave/uma-slave
Restart=always
RestartSec=3

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
